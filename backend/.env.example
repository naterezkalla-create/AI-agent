# ===========================================
# AI Agent — Environment Variables
# ===========================================
# Copy this to .env and fill in your values.

# App
APP_NAME="AI Agent"
DEBUG=false
API_KEY=           # Set a bearer token for API auth (leave blank to disable)

# Anthropic
ANTHROPIC_API_KEY= # Required — get from https://console.anthropic.com

# Supabase
SUPABASE_URL=      # Required — your Supabase project URL
SUPABASE_KEY=      # Required — service_role key (not anon key)

# Authentication & JWT
JWT_SECRET=       # Generate a long random string for JWT signing
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=168 # Token expiration time (7 days)

# Email Configuration (for verification & password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=        # Your email address for sending emails
SMTP_PASSWORD=    # App-specific password (for Gmail: https://myaccount.google.com/apppasswords)
FROM_EMAIL=       # Email address to send from (usually same as SMTP_USER)
FROM_NAME=AI Agent
FRONTEND_URL=http://localhost:5173 # Frontend URL for email links

# Telegram
TELEGRAM_BOT_TOKEN=      # Get from @BotFather on Telegram
TELEGRAM_WEBHOOK_URL=    # Public URL of your server (e.g. https://yourdomain.com)

# Search (Tavily)
TAVILY_API_KEY=    # Get from https://tavily.com

# Google OAuth (for Gmail + Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/integrations/google/callback

# Encryption (for OAuth tokens at rest)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Sandbox
SANDBOX_DIR=/tmp/agent-sandbox

# Scheduler
SCHEDULER_ENABLED=true

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO
